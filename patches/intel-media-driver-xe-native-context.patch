diff --git a/media_softlet/linux/common/os/xe/mos_xe_virtio.c b/media_softlet/linux/common/os/xe/mos_xe_virtio.c
new file mode 100644
index 0000000..7b7b984
--- /dev/null
+++ b/media_softlet/linux/common/os/xe/mos_xe_virtio.c
@@ -0,0 +1,1285 @@
+/*
+ * Copyright 2025 Intel Corporation
+ * SPDX-License-Identifier: MIT
+ *
+ * Virtio-GPU Xe native context support for the iHD media driver.
+ *
+ * Self-contained vdrm client + Xe ccmd translation layer adapted from
+ * mesa's src/virtio/vdrm/ and src/intel/dev/virtio/xe_virtio_ccmd.c.
+ *
+ * This file is compiled as C++ (like all .c files in iHD) via
+ * set_source_files_properties(... LANGUAGE "CXX") in cmake.
+ */
+
+#include "mos_xe_virtio.h"
+
+#include <assert.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <pthread.h>
+#include <poll.h>
+#include <sched.h>
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/mman.h>
+#include <unistd.h>
+
+#include <xf86drm.h>
+#include <libdrm/virtgpu_drm.h>
+
+/* Pick up xe_drm.h from the system or the tree -- the same header
+ * mos_bufmgr_xe.c already uses.
+ */
+#include <drm/xe_drm.h>
+
+/* Use simple fprintf for logging — avoids dependency on iHD's debug infra
+ * which pulls in too many headers for a standalone C file.
+ */
+#define MOS_DRM_ASSERTMESSAGE(fmt, ...) \
+   fprintf(stderr, "intel-media-driver-virtio: " fmt "\n", ##__VA_ARGS__)
+
+/* ======================================================================
+ * Helpers replacing mesa utilities
+ * ====================================================================== */
+
+static inline uint32_t
+virtio_align(uint32_t v, uint32_t a)
+{
+    return (v + a - 1) & ~(a - 1);
+}
+
+#ifndef MIN2
+#define MIN2(a, b) ((a) < (b) ? (a) : (b))
+#endif
+
+#ifndef ARRAY_SIZE
+#define ARRAY_SIZE(x) (sizeof(x) / sizeof((x)[0]))
+#endif
+
+/* ======================================================================
+ * vdrm protocol structures (from mesa's drm_hw.h)
+ * ====================================================================== */
+
+struct virgl_renderer_capset_drm {
+    uint32_t wire_format_version;
+    uint32_t version_major;
+    uint32_t version_minor;
+    uint32_t version_patchlevel;
+#define VIRTGPU_DRM_CONTEXT_XE 6
+    uint32_t context_type;
+    uint32_t pad;
+    union {
+        struct {
+            uint32_t pci_bus;
+            uint32_t pci_dev;
+            uint32_t pci_func;
+            uint32_t pci_revision_id;
+            uint32_t pci_domain;
+            uint32_t pci_device_id;
+        } xe;
+    } u;
+};
+
+struct vdrm_shmem {
+    uint32_t seqno;
+    uint32_t rsp_mem_offset;
+};
+
+struct vdrm_ccmd_req {
+    uint32_t cmd;
+    uint32_t len;
+    uint32_t seqno;
+    uint32_t rsp_off;
+};
+
+struct vdrm_ccmd_rsp {
+    uint32_t len;
+};
+
+/* ======================================================================
+ * Xe virtio protocol structures (from xe_virtio_proto.h)
+ * Must be kept in sync with virglrenderer's src/drm/xe/xe_proto.h.
+ * ====================================================================== */
+
+enum xe_ccmd {
+    XE_CCMD_NOP                = 0,
+    XE_CCMD_DEVICE_QUERY       = 1,
+    XE_CCMD_GEM_CREATE         = 2,
+    XE_CCMD_VM_CREATE          = 3,
+    XE_CCMD_VM_DESTROY         = 4,
+    XE_CCMD_VM_BIND            = 5,
+    XE_CCMD_EXEC_QUEUE_CREATE  = 6,
+    XE_CCMD_EXEC_QUEUE_DESTROY = 7,
+    XE_CCMD_EXEC               = 8,
+};
+
+#define XE_CCMD_HDR(_cmd, _len) \
+    (struct vdrm_ccmd_req){ .cmd = (_cmd), .len = (_len) }
+
+struct xe_shmem {
+    struct vdrm_shmem base;
+    uint64_t banned_exec_queue_mask;
+};
+
+struct xe_ccmd_device_query_req {
+    struct vdrm_ccmd_req hdr;
+    uint32_t query;
+    uint32_t size;
+};
+
+struct xe_ccmd_device_query_rsp {
+    struct vdrm_ccmd_rsp hdr;
+    uint32_t pad;
+    int32_t  ret;
+    uint32_t size;
+    uint8_t  payload[];
+};
+
+struct xe_ccmd_gem_create_req {
+    struct vdrm_ccmd_req hdr;
+    uint64_t size;
+    uint32_t placement;
+    uint32_t flags;
+    uint32_t vm_id;
+    uint32_t blob_id;
+    uint16_t cpu_caching;
+    uint16_t pad[3];
+};
+
+struct xe_ccmd_vm_create_req {
+    struct vdrm_ccmd_req hdr;
+    uint32_t flags;
+    uint32_t pad;
+};
+
+struct xe_ccmd_vm_create_rsp {
+    struct vdrm_ccmd_rsp hdr;
+    uint32_t pad;
+    int32_t  ret;
+    uint32_t vm_id;
+};
+
+struct xe_ccmd_vm_destroy_req {
+    struct vdrm_ccmd_req hdr;
+    uint32_t vm_id;
+    uint32_t pad;
+};
+
+struct xe_ccmd_vm_bind_op {
+    uint32_t res_id;
+    uint16_t pat_index;
+    uint16_t pad;
+    uint64_t obj_offset;
+    uint64_t range;
+    uint64_t addr;
+    uint32_t op;
+    uint32_t flags;
+};
+
+struct xe_ccmd_vm_bind_req {
+    struct vdrm_ccmd_req hdr;
+    uint32_t vm_id;
+    uint32_t num_binds;
+    uint8_t  payload[];
+};
+
+struct xe_ccmd_vm_bind_rsp {
+    struct vdrm_ccmd_rsp hdr;
+    uint32_t pad;
+    int32_t  ret;
+    uint32_t pad2;
+};
+
+struct xe_ccmd_exec_queue_create_req {
+    struct vdrm_ccmd_req hdr;
+    uint32_t vm_id;
+    uint32_t flags;
+    uint16_t width;
+    uint16_t num_placements;
+    uint32_t pad;
+    uint8_t  payload[];
+};
+
+struct xe_ccmd_exec_queue_create_rsp {
+    struct vdrm_ccmd_rsp hdr;
+    uint32_t pad;
+    int32_t  ret;
+    uint32_t exec_queue_id;
+};
+
+struct xe_ccmd_exec_queue_destroy_req {
+    struct vdrm_ccmd_req hdr;
+    uint32_t exec_queue_id;
+    uint32_t pad;
+};
+
+struct xe_ccmd_exec_req {
+    struct vdrm_ccmd_req hdr;
+    uint32_t exec_queue_id;
+    uint16_t num_batch_buffer;
+    uint16_t pad;
+    uint64_t address;
+};
+
+struct xe_ccmd_exec_rsp {
+    struct vdrm_ccmd_rsp hdr;
+    int32_t  ret;
+};
+
+/* ======================================================================
+ * vdrm client state
+ * ====================================================================== */
+
+#define VDRM_SHMEM_SZ  0x4000
+#define VDRM_REQBUF_SZ 0x4000
+
+struct vdrm_device {
+    int fd;         /* vdrm protocol fd (may be reopened) */
+
+    struct vdrm_shmem *shmem;
+    uint8_t           *rsp_mem;
+    uint32_t           rsp_mem_len;
+    uint32_t           next_rsp_off;
+
+    uint32_t shmem_handle;
+
+    uint32_t next_seqno;
+    uint32_t next_blob_id;
+
+    pthread_mutex_t rsp_lock;
+    pthread_mutex_t eb_lock;
+
+    uint32_t reqbuf_len;
+    uint32_t reqbuf_cnt;
+    uint8_t  reqbuf[VDRM_REQBUF_SZ];
+
+    struct virgl_renderer_capset_drm caps;
+};
+
+/* Single-instance design: only one active vdrm connection at a time.
+ * This matches the media driver's usage model (one device context per
+ * process).  Multi-device support would require per-fd state tracking.
+ */
+static struct vdrm_device *g_vdrm = NULL;
+static int g_vdrm_fd = -1;
+static pthread_mutex_t g_vdrm_global_lock = PTHREAD_MUTEX_INITIALIZER;
+
+/* ======================================================================
+ * Low-level virtgpu helpers
+ * ====================================================================== */
+
+static int
+virtgpu_ioctl(int fd, unsigned long request, void *arg)
+{
+    return drmIoctl(fd, request, arg);
+}
+
+static void
+virtgpu_gem_close(int fd, uint32_t handle)
+{
+    struct drm_gem_close c = { .handle = handle };
+    drmIoctl(fd, DRM_IOCTL_GEM_CLOSE, &c);
+}
+
+static int
+virtgpu_map_handle(int fd, uint32_t handle, size_t size, void **out, void *placed)
+{
+    struct drm_virtgpu_map req;
+    memset(&req, 0, sizeof(req));
+    req.handle = handle;
+
+    int ret = drmIoctl(fd, DRM_IOCTL_VIRTGPU_MAP, &req);
+    if (ret) {
+        MOS_DRM_ASSERTMESSAGE("VIRTGPU_MAP failed: %s", strerror(errno));
+        return ret;
+    }
+
+    *out = mmap(placed, size, PROT_READ | PROT_WRITE,
+                MAP_SHARED | (placed ? MAP_FIXED : 0),
+                fd, req.offset);
+    if (*out == MAP_FAILED) {
+        MOS_DRM_ASSERTMESSAGE("mmap failed: %s", strerror(errno));
+        return -1;
+    }
+    return 0;
+}
+
+/* ======================================================================
+ * vdrm client implementation
+ * ====================================================================== */
+
+static int
+vdrm_get_capset(int fd, struct virgl_renderer_capset_drm *caps)
+{
+    struct drm_virtgpu_get_caps args;
+    memset(&args, 0, sizeof(args));
+    args.cap_set_id  = VIRTGPU_DRM_CAPSET_DRM;
+    args.cap_set_ver = 0;
+    args.addr        = (uintptr_t)caps;
+    args.size        = sizeof(*caps);
+
+    memset(caps, 0, sizeof(*caps));
+    return drmIoctl(fd, DRM_IOCTL_VIRTGPU_GET_CAPS, &args);
+}
+
+static int
+vdrm_set_context(int fd)
+{
+    struct drm_virtgpu_context_set_param params[] = {
+        { VIRTGPU_CONTEXT_PARAM_CAPSET_ID,  VIRTGPU_DRM_CAPSET_DRM },
+        { VIRTGPU_CONTEXT_PARAM_NUM_RINGS,  64 },
+    };
+    struct drm_virtgpu_context_init args;
+    memset(&args, 0, sizeof(args));
+    args.num_params    = ARRAY_SIZE(params);
+    args.ctx_set_params = (uintptr_t)params;
+
+    return drmIoctl(fd, DRM_IOCTL_VIRTGPU_CONTEXT_INIT, &args);
+}
+
+static int
+vdrm_init_shmem(struct vdrm_device *vdev)
+{
+    struct drm_virtgpu_resource_create_blob blob;
+    memset(&blob, 0, sizeof(blob));
+    blob.blob_mem   = VIRTGPU_BLOB_MEM_HOST3D;
+    blob.blob_flags = VIRTGPU_BLOB_FLAG_USE_MAPPABLE;
+    blob.size       = VDRM_SHMEM_SZ;
+    blob.blob_id    = 0;
+
+    int ret = drmIoctl(vdev->fd, DRM_IOCTL_VIRTGPU_RESOURCE_CREATE_BLOB, &blob);
+    if (ret) {
+        MOS_DRM_ASSERTMESSAGE("vdrm shmem alloc failed: %s", strerror(errno));
+        return ret;
+    }
+
+    vdev->shmem_handle = blob.bo_handle;
+
+    ret = virtgpu_map_handle(vdev->fd, vdev->shmem_handle,
+                             blob.size, (void **)&vdev->shmem, NULL);
+    if (ret) {
+        virtgpu_gem_close(vdev->fd, vdev->shmem_handle);
+        vdev->shmem_handle = 0;
+        return ret;
+    }
+
+    uint32_t offset = vdev->shmem->rsp_mem_offset;
+    vdev->rsp_mem_len = VDRM_SHMEM_SZ - offset;
+    vdev->rsp_mem     = &((uint8_t *)vdev->shmem)[offset];
+
+    return 0;
+}
+
+static struct vdrm_device *
+vdrm_connect(int fd)
+{
+    struct virgl_renderer_capset_drm caps;
+    int ret;
+
+    ret = vdrm_get_capset(fd, &caps);
+    if (ret)
+        return NULL;
+
+    if (caps.context_type != VIRTGPU_DRM_CONTEXT_XE)
+        return NULL;
+
+    ret = vdrm_set_context(fd);
+    if (ret && errno == EEXIST) {
+        /* Context already exists on this fd (e.g. mesa/zink).
+         * Reopen to get our own context — needed for shmem mmap.
+         */
+        char path[64];
+        snprintf(path, sizeof(path), "/proc/self/fd/%d", fd);
+        int own_fd = open(path, O_RDWR | O_CLOEXEC);
+        if (own_fd < 0)
+            return NULL;
+        ret = vdrm_set_context(own_fd);
+        if (ret) {
+            close(own_fd);
+            return NULL;
+        }
+        fd = own_fd;
+    } else if (ret) {
+        return NULL;
+    }
+
+    struct vdrm_device *vdev = (struct vdrm_device *)calloc(1, sizeof(*vdev));
+    if (!vdev)
+        return NULL;
+
+    vdev->fd = fd;
+    pthread_mutex_init(&vdev->rsp_lock, NULL);
+    pthread_mutex_init(&vdev->eb_lock, NULL);
+
+    ret = vdrm_init_shmem(vdev);
+    if (ret) {
+        free(vdev);
+        return NULL;
+    }
+
+    vdev->caps = caps;
+    return vdev;
+}
+
+static void
+vdrm_disconnect(struct vdrm_device *vdev)
+{
+    if (!vdev)
+        return;
+
+    /* Flush outstanding requests before tearing down. */
+    pthread_mutex_lock(&vdev->eb_lock);
+    /* best-effort flush */
+    if (vdev->reqbuf_len > 0) {
+        struct drm_virtgpu_execbuffer eb;
+        memset(&eb, 0, sizeof(eb));
+        eb.flags   = VIRTGPU_EXECBUF_RING_IDX;
+        eb.size    = vdev->reqbuf_len;
+        eb.command = (uintptr_t)vdev->reqbuf;
+        drmIoctl(vdev->fd, DRM_IOCTL_VIRTGPU_EXECBUFFER, &eb);
+        vdev->reqbuf_len = 0;
+        vdev->reqbuf_cnt = 0;
+    }
+    pthread_mutex_unlock(&vdev->eb_lock);
+
+    if (vdev->shmem)
+        munmap(vdev->shmem, VDRM_SHMEM_SZ);
+    if (vdev->shmem_handle)
+        virtgpu_gem_close(vdev->fd, vdev->shmem_handle);
+
+    pthread_mutex_destroy(&vdev->rsp_lock);
+    pthread_mutex_destroy(&vdev->eb_lock);
+    free(vdev);
+}
+
+/* ---- response allocation ---- */
+
+static void *
+vdrm_alloc_rsp(struct vdrm_device *vdev, struct vdrm_ccmd_req *req, uint32_t sz)
+{
+    uint32_t off;
+
+    pthread_mutex_lock(&vdev->rsp_lock);
+
+    sz = virtio_align(sz, 8);
+
+    if ((vdev->next_rsp_off + sz) >= vdev->rsp_mem_len)
+        vdev->next_rsp_off = 0;
+
+    off = vdev->next_rsp_off;
+    vdev->next_rsp_off += sz;
+
+    pthread_mutex_unlock(&vdev->rsp_lock);
+
+    req->rsp_off = off;
+
+    struct vdrm_ccmd_rsp *rsp = (struct vdrm_ccmd_rsp *)&vdev->rsp_mem[off];
+    rsp->len = sz;
+
+    return rsp;
+}
+
+/* ---- fence helpers ---- */
+
+static bool
+fence_before(uint32_t a, uint32_t b)
+{
+    return (int32_t)(a - b) < 0;
+}
+
+static void
+vdrm_host_sync(struct vdrm_device *vdev, const struct vdrm_ccmd_req *req)
+{
+    while (fence_before(vdev->shmem->seqno, req->seqno))
+        sched_yield();
+}
+
+/* ---- flush / execbuf ---- */
+
+static int
+vdrm_flush_locked(struct vdrm_device *vdev, int *out_fence_fd)
+{
+    if (!vdev->reqbuf_len)
+        return 0;
+
+    struct drm_virtgpu_execbuffer eb;
+    memset(&eb, 0, sizeof(eb));
+    eb.flags   = VIRTGPU_EXECBUF_RING_IDX;
+    eb.size    = vdev->reqbuf_len;
+    eb.command = (uintptr_t)vdev->reqbuf;
+
+    if (out_fence_fd) {
+        eb.flags |= VIRTGPU_EXECBUF_FENCE_FD_OUT;
+    }
+
+    int ret = drmIoctl(vdev->fd, DRM_IOCTL_VIRTGPU_EXECBUFFER, &eb);
+    if (ret) {
+        MOS_DRM_ASSERTMESSAGE("VIRTGPU_EXECBUFFER flush failed: %s", strerror(errno));
+        return ret;
+    }
+
+    vdev->reqbuf_len = 0;
+    vdev->reqbuf_cnt = 0;
+
+    if (out_fence_fd)
+        *out_fence_fd = eb.fence_fd;
+
+    return 0;
+}
+
+static int
+vdrm_enqueue_req(struct vdrm_device *vdev, struct vdrm_ccmd_req *req)
+{
+    /* Caller holds eb_lock */
+    req->seqno = ++vdev->next_seqno;
+
+    if ((vdev->reqbuf_len + req->len) > sizeof(vdev->reqbuf)) {
+        int ret = vdrm_flush_locked(vdev, NULL);
+        if (ret)
+            return ret;
+    }
+
+    memcpy(&vdev->reqbuf[vdev->reqbuf_len], req, req->len);
+    vdev->reqbuf_len += req->len;
+    vdev->reqbuf_cnt++;
+
+    return 0;
+}
+
+/**
+ * Send a ccmd request. If @p sync is true, flush and wait for the
+ * host to process the command (blocking).
+ */
+static int
+vdrm_send_req(struct vdrm_device *vdev, struct vdrm_ccmd_req *req, bool sync)
+{
+    int fence_fd = -1;
+    int ret = 0;
+
+    pthread_mutex_lock(&vdev->eb_lock);
+    ret = vdrm_enqueue_req(vdev, req);
+
+    if (ret || !sync)
+        goto unlock;
+
+    ret = vdrm_flush_locked(vdev, &fence_fd);
+
+unlock:
+    pthread_mutex_unlock(&vdev->eb_lock);
+
+    if (ret)
+        return ret;
+
+    if (sync) {
+        /* Wait for the fence, then spin until host writes seqno. */
+        if (fence_fd >= 0) {
+            /* poll on the fence fd until signaled */
+            struct pollfd pfd = { .fd = fence_fd, .events = POLLIN };
+            while (poll(&pfd, 1, -1) == -1 && errno == EINTR)
+                ;
+            close(fence_fd);
+        }
+        vdrm_host_sync(vdev, req);
+    }
+
+    return 0;
+}
+
+/**
+ * Create a GEM object on the host via RESOURCE_CREATE_BLOB + ccmd.
+ * Returns the guest GEM handle, or 0 on failure.
+ */
+static uint32_t
+vdrm_bo_create(struct vdrm_device *vdev, size_t size, uint32_t blob_flags,
+               uint64_t blob_id, struct vdrm_ccmd_req *req)
+{
+    pthread_mutex_lock(&vdev->eb_lock);
+
+    /* Flush buffered cmds so host sees them before the blob create. */
+    vdrm_flush_locked(vdev, NULL);
+
+    req->seqno = ++vdev->next_seqno;
+
+    struct drm_virtgpu_resource_create_blob args;
+    memset(&args, 0, sizeof(args));
+    args.blob_mem   = VIRTGPU_BLOB_MEM_HOST3D;
+    args.blob_flags = blob_flags;
+    args.size       = size;
+    args.cmd_size   = req->len;
+    args.cmd        = (uintptr_t)req;
+    args.blob_id    = blob_id;
+
+    int ret = drmIoctl(vdev->fd, DRM_IOCTL_VIRTGPU_RESOURCE_CREATE_BLOB, &args);
+
+    pthread_mutex_unlock(&vdev->eb_lock);
+
+    if (ret) {
+        MOS_DRM_ASSERTMESSAGE("vdrm bo_create failed: %s", strerror(errno));
+        return 0;
+    }
+
+    return args.bo_handle;
+}
+
+/**
+ * Close a BO -- flush first so detach_resource doesn't race.
+ */
+static void
+vdrm_bo_close(struct vdrm_device *vdev, uint32_t handle)
+{
+    if (vdev->reqbuf_len) {
+        pthread_mutex_lock(&vdev->eb_lock);
+        vdrm_flush_locked(vdev, NULL);
+        pthread_mutex_unlock(&vdev->eb_lock);
+    }
+    virtgpu_gem_close(vdev->fd, handle);
+}
+
+/**
+ * Get the virtgpu resource id for a GEM handle.
+ */
+static uint32_t
+vdrm_handle_to_res_id(struct vdrm_device *vdev, uint32_t handle)
+{
+    struct drm_virtgpu_resource_info info;
+    memset(&info, 0, sizeof(info));
+    info.bo_handle = handle;
+
+    int ret = drmIoctl(vdev->fd, DRM_IOCTL_VIRTGPU_RESOURCE_INFO, &info);
+    if (ret) {
+        MOS_DRM_ASSERTMESSAGE("RESOURCE_INFO failed: %s", strerror(errno));
+        return 0;
+    }
+    return info.res_handle;
+}
+
+/**
+ * Submit a ccmd that participates in execbuf (with syncobjs).
+ */
+static int
+vdrm_execbuf(struct vdrm_device *vdev,
+             struct vdrm_ccmd_req *req,
+             uint32_t ring_idx,
+             struct drm_virtgpu_execbuffer_syncobj *in_so, uint32_t n_in,
+             struct drm_virtgpu_execbuffer_syncobj *out_so, uint32_t n_out)
+{
+    int ret = 0;
+
+    pthread_mutex_lock(&vdev->eb_lock);
+
+    req->seqno = ++vdev->next_seqno;
+
+    ret = vdrm_flush_locked(vdev, NULL);
+    if (ret)
+        goto unlock;
+
+    {
+        struct drm_virtgpu_execbuffer eb;
+        memset(&eb, 0, sizeof(eb));
+        eb.flags          = VIRTGPU_EXECBUF_RING_IDX;
+        eb.size           = req->len;
+        eb.command        = (uintptr_t)req;
+        eb.ring_idx       = ring_idx;
+        eb.syncobj_stride = sizeof(struct drm_virtgpu_execbuffer_syncobj);
+        eb.num_in_syncobjs  = n_in;
+        eb.num_out_syncobjs = n_out;
+        eb.in_syncobjs    = (uintptr_t)in_so;
+        eb.out_syncobjs   = (uintptr_t)out_so;
+
+        ret = drmIoctl(vdev->fd, DRM_IOCTL_VIRTGPU_EXECBUFFER, &eb);
+        if (ret) {
+            MOS_DRM_ASSERTMESSAGE("VIRTGPU_EXECBUFFER execbuf failed: %s",
+                                  strerror(errno));
+        }
+    }
+
+unlock:
+    pthread_mutex_unlock(&vdev->eb_lock);
+    return ret;
+}
+
+/* ======================================================================
+ * Xe ioctl handlers
+ * ====================================================================== */
+
+static int
+handle_device_query(struct vdrm_device *vdev, struct drm_xe_device_query *query)
+{
+    if (query->size == 0) {
+        /* Phase 1: probe size */
+        struct xe_ccmd_device_query_req req = {
+            .hdr   = XE_CCMD_HDR(XE_CCMD_DEVICE_QUERY, sizeof(req)),
+            .query = query->query,
+            .size  = 0,
+        };
+        struct xe_ccmd_device_query_rsp *rsp =
+            (struct xe_ccmd_device_query_rsp *)
+            vdrm_alloc_rsp(vdev, &req.hdr, sizeof(*rsp));
+
+        int ret = vdrm_send_req(vdev, &req.hdr, true);
+        if (ret)
+            return ret;
+        if (rsp->ret)
+            return rsp->ret;
+
+        query->size = rsp->size;
+        return 0;
+    }
+
+    /* Phase 2: fetch data */
+    struct xe_ccmd_device_query_req req = {
+        .hdr   = XE_CCMD_HDR(XE_CCMD_DEVICE_QUERY, sizeof(req)),
+        .query = query->query,
+        .size  = query->size,
+    };
+    uint32_t rsp_sz = sizeof(struct xe_ccmd_device_query_rsp) +
+                      virtio_align(query->size, 8);
+    struct xe_ccmd_device_query_rsp *rsp =
+        (struct xe_ccmd_device_query_rsp *)
+        vdrm_alloc_rsp(vdev, &req.hdr, rsp_sz);
+
+    int ret = vdrm_send_req(vdev, &req.hdr, true);
+    if (ret)
+        return ret;
+    if (rsp->ret)
+        return rsp->ret;
+
+    uint32_t copy_sz = MIN2(query->size, rsp->size);
+    memcpy((void *)(uintptr_t)query->data, rsp->payload, copy_sz);
+    query->size = rsp->size;
+    return 0;
+}
+
+static int
+handle_gem_create(struct vdrm_device *vdev, struct drm_xe_gem_create *args)
+{
+    uint32_t blob_id = __sync_add_and_fetch(&vdev->next_blob_id, 1);
+
+    struct xe_ccmd_gem_create_req req = {
+        .hdr         = XE_CCMD_HDR(XE_CCMD_GEM_CREATE, sizeof(req)),
+        .size        = args->size,
+        .placement   = args->placement,
+        .flags       = args->flags,
+        .vm_id       = args->vm_id,
+        .blob_id     = blob_id,
+        .cpu_caching = args->cpu_caching,
+    };
+
+    uint32_t blob_flags = VIRTGPU_BLOB_FLAG_USE_MAPPABLE |
+                          VIRTGPU_BLOB_FLAG_USE_SHAREABLE;
+
+    uint32_t handle = vdrm_bo_create(vdev, args->size,
+                                     blob_flags, blob_id, &req.hdr);
+    if (!handle)
+        return -ENOMEM;
+
+    args->handle = handle;
+    return 0;
+}
+
+static int
+handle_gem_mmap_offset(struct vdrm_device *vdev,
+                       struct drm_xe_gem_mmap_offset *args)
+{
+    /* On virtio we cannot use the Xe mmap_offset path.  The caller
+     * (mos_bo_map_xe) is patched to call mos_xe_gem_mmap() instead
+     * when the virtio proxy is active.  Return -ENOSYS to catch any
+     * unexpected call.
+     */
+    (void)vdev;
+    (void)args;
+    return -ENOSYS;
+}
+
+static int
+handle_vm_create(struct vdrm_device *vdev, struct drm_xe_vm_create *args)
+{
+    struct xe_ccmd_vm_create_req req = {
+        .hdr   = XE_CCMD_HDR(XE_CCMD_VM_CREATE, sizeof(req)),
+        .flags = args->flags,
+    };
+    struct xe_ccmd_vm_create_rsp *rsp =
+        (struct xe_ccmd_vm_create_rsp *)
+        vdrm_alloc_rsp(vdev, &req.hdr, sizeof(*rsp));
+
+    int ret = vdrm_send_req(vdev, &req.hdr, true);
+    if (ret)
+        return ret;
+    if (rsp->ret)
+        return -(int)rsp->ret;
+
+    args->vm_id = rsp->vm_id;
+    return 0;
+}
+
+static int
+handle_vm_destroy(struct vdrm_device *vdev, struct drm_xe_vm_destroy *args)
+{
+    struct xe_ccmd_vm_destroy_req req = {
+        .hdr   = XE_CCMD_HDR(XE_CCMD_VM_DESTROY, sizeof(req)),
+        .vm_id = args->vm_id,
+    };
+    return vdrm_send_req(vdev, &req.hdr, false);
+}
+
+static int
+handle_vm_bind(struct vdrm_device *vdev, struct drm_xe_vm_bind *args)
+{
+    uint32_t num_binds = args->num_binds;
+    if (num_binds == 0)
+        num_binds = 1;  /* inline bind */
+
+    size_t payload_sz = num_binds * sizeof(struct xe_ccmd_vm_bind_op);
+    size_t req_sz = sizeof(struct xe_ccmd_vm_bind_req) + payload_sz;
+
+    struct xe_ccmd_vm_bind_req *req =
+        (struct xe_ccmd_vm_bind_req *)calloc(1, req_sz);
+    if (!req)
+        return -ENOMEM;
+
+    req->hdr = XE_CCMD_HDR(XE_CCMD_VM_BIND, (uint32_t)req_sz);
+    req->vm_id = args->vm_id;
+    req->num_binds = num_binds;
+
+    struct xe_ccmd_vm_bind_op *ops =
+        (struct xe_ccmd_vm_bind_op *)req->payload;
+
+    if (args->num_binds <= 1) {
+        /* Inline bind (the common iHD path) */
+        uint32_t handle = args->bind.obj;
+        uint32_t res_id = 0;
+        if (handle)
+            res_id = vdrm_handle_to_res_id(vdev, handle);
+
+        ops[0].res_id     = res_id;
+        ops[0].pat_index  = args->bind.pat_index;
+        ops[0].obj_offset = args->bind.obj_offset;
+        ops[0].range      = args->bind.range;
+        ops[0].addr       = args->bind.addr;
+        ops[0].op         = args->bind.op;
+        ops[0].flags      = args->bind.flags;
+    } else {
+        struct drm_xe_vm_bind_op *src =
+            (struct drm_xe_vm_bind_op *)(uintptr_t)args->vector_of_binds;
+        for (uint32_t i = 0; i < num_binds; i++) {
+            uint32_t handle = src[i].obj;
+            uint32_t res_id = 0;
+            if (handle)
+                res_id = vdrm_handle_to_res_id(vdev, handle);
+
+            ops[i].res_id     = res_id;
+            ops[i].pat_index  = src[i].pat_index;
+            ops[i].obj_offset = src[i].obj_offset;
+            ops[i].range      = src[i].range;
+            ops[i].addr       = src[i].addr;
+            ops[i].op         = src[i].op;
+            ops[i].flags      = src[i].flags;
+        }
+    }
+
+    struct xe_ccmd_vm_bind_rsp *rsp =
+        (struct xe_ccmd_vm_bind_rsp *)
+        vdrm_alloc_rsp(vdev, &req->hdr, sizeof(*rsp));
+
+    int ret = vdrm_send_req(vdev, &req->hdr, true);
+    int err = ret ? ret : rsp->ret;
+    free(req);
+
+    if (err)
+        return -abs(err);
+
+    /* Signal any out-syncobjs the caller attached (iHD creates a temp
+     * syncobj in mos_vm_bind_sync_xe and waits on it).
+     */
+    if (args->num_syncs > 0) {
+        struct drm_xe_sync *syncs =
+            (struct drm_xe_sync *)(uintptr_t)args->syncs;
+        for (uint32_t i = 0; i < args->num_syncs; i++) {
+            if (syncs[i].flags & DRM_XE_SYNC_FLAG_SIGNAL) {
+                struct drm_syncobj_array sig;
+                memset(&sig, 0, sizeof(sig));
+                sig.handles       = (uintptr_t)&syncs[i].handle;
+                sig.count_handles = 1;
+                drmIoctl(g_vdrm_fd, DRM_IOCTL_SYNCOBJ_SIGNAL, &sig);
+            }
+        }
+    }
+
+    return 0;
+}
+
+static int
+handle_exec_queue_create(struct vdrm_device *vdev,
+                         struct drm_xe_exec_queue_create *args)
+{
+    uint32_t n_instances = (uint32_t)args->width * args->num_placements;
+    size_t instances_sz = n_instances *
+                          sizeof(struct drm_xe_engine_class_instance);
+    size_t req_sz = sizeof(struct xe_ccmd_exec_queue_create_req) + instances_sz;
+
+    struct xe_ccmd_exec_queue_create_req *req =
+        (struct xe_ccmd_exec_queue_create_req *)calloc(1, req_sz);
+    if (!req)
+        return -ENOMEM;
+
+    req->hdr            = XE_CCMD_HDR(XE_CCMD_EXEC_QUEUE_CREATE, (uint32_t)req_sz);
+    req->vm_id          = args->vm_id;
+    req->width          = args->width;
+    req->num_placements = args->num_placements;
+    req->flags          = args->flags;
+
+    memcpy(req->payload, (void *)(uintptr_t)args->instances, instances_sz);
+
+    struct xe_ccmd_exec_queue_create_rsp *rsp =
+        (struct xe_ccmd_exec_queue_create_rsp *)
+        vdrm_alloc_rsp(vdev, &req->hdr, sizeof(*rsp));
+
+    int ret = vdrm_send_req(vdev, &req->hdr, true);
+    free(req);
+
+    if (ret)
+        return ret;
+    if (rsp->ret)
+        return -(int)rsp->ret;
+
+    args->exec_queue_id = rsp->exec_queue_id;
+    return 0;
+}
+
+static int
+handle_exec_queue_destroy(struct vdrm_device *vdev,
+                          struct drm_xe_exec_queue_destroy *args)
+{
+    struct xe_ccmd_exec_queue_destroy_req req = {
+        .hdr           = XE_CCMD_HDR(XE_CCMD_EXEC_QUEUE_DESTROY, sizeof(req)),
+        .exec_queue_id = args->exec_queue_id,
+    };
+    return vdrm_send_req(vdev, &req.hdr, false);
+}
+
+static int
+handle_exec(struct vdrm_device *vdev, struct drm_xe_exec *args)
+{
+    struct xe_ccmd_exec_req req = {
+        .hdr              = XE_CCMD_HDR(XE_CCMD_EXEC, sizeof(req)),
+        .exec_queue_id    = args->exec_queue_id,
+        .num_batch_buffer = args->num_batch_buffer,
+        .address          = args->address,
+    };
+
+    struct drm_xe_sync *xe_syncs =
+        (struct drm_xe_sync *)(uintptr_t)args->syncs;
+    uint32_t n_in = 0, n_out = 0;
+
+    for (uint32_t i = 0; i < args->num_syncs; i++) {
+        if (xe_syncs[i].flags & DRM_XE_SYNC_FLAG_SIGNAL)
+            n_out++;
+        else
+            n_in++;
+    }
+
+    struct drm_virtgpu_execbuffer_syncobj *in_so = NULL;
+    struct drm_virtgpu_execbuffer_syncobj *out_so = NULL;
+
+    if (n_in) {
+        in_so = (struct drm_virtgpu_execbuffer_syncobj *)
+                calloc(n_in, sizeof(*in_so));
+        if (!in_so)
+            return -ENOMEM;
+    }
+    if (n_out) {
+        out_so = (struct drm_virtgpu_execbuffer_syncobj *)
+                 calloc(n_out, sizeof(*out_so));
+        if (!out_so) {
+            free(in_so);
+            return -ENOMEM;
+        }
+    }
+
+    uint32_t ii = 0, oi = 0;
+    for (uint32_t i = 0; i < args->num_syncs; i++) {
+        struct drm_xe_sync *s = &xe_syncs[i];
+        if (s->flags & DRM_XE_SYNC_FLAG_SIGNAL) {
+            out_so[oi].handle = s->handle;
+            out_so[oi].flags  = 0;
+            out_so[oi].point  = s->timeline_value;
+            oi++;
+        } else {
+            in_so[ii].handle = s->handle;
+            in_so[ii].flags  = 0;
+            in_so[ii].point  = s->timeline_value;
+            ii++;
+        }
+    }
+
+    /* Submit on ring exec_queue_id + 1 (ring 0 is the control ring).
+     * This ties the virtio fence to the host's drm_timeline for this
+     * exec queue, which signals after actual GPU completion.
+     *
+     * If the fd was reopened (EEXIST), syncobj handles belong to the
+     * caller's fd, not vdev->fd. Use FENCE_FD_OUT to get a fd-portable
+     * fence, then import it into the caller's syncobjs.
+     */
+    bool reopened = (vdev->fd != g_vdrm_fd);
+
+    if (!reopened) {
+        /* Normal case: syncobjs are on the same fd, pass them directly */
+        int ret = vdrm_execbuf(vdev, &req.hdr, args->exec_queue_id + 1,
+                               in_so, n_in, out_so, n_out);
+        free(in_so);
+        free(out_so);
+        return ret;
+    }
+
+    /* Reopened fd case: syncobj handles belong to the caller's fd, not
+     * vdev->fd, so we cannot pass them directly.  Instead, use
+     * FENCE_FD_OUT, wait for GPU completion, then signal the caller's
+     * syncobjs.  This blocks the submission thread but preserves
+     * timeline ordering correctness.
+     */
+    free(in_so);
+    free(out_so);
+
+    pthread_mutex_lock(&vdev->eb_lock);
+    vdrm_flush_locked(vdev, NULL);
+
+    req.hdr.seqno = ++vdev->next_seqno;
+
+    struct drm_virtgpu_execbuffer eb;
+    memset(&eb, 0, sizeof(eb));
+    eb.flags    = VIRTGPU_EXECBUF_RING_IDX;
+    eb.size     = sizeof(req);
+    eb.command  = (uintptr_t)&req;
+    eb.ring_idx = args->exec_queue_id + 1;
+
+    if (n_out)
+        eb.flags |= VIRTGPU_EXECBUF_FENCE_FD_OUT;
+
+    int ret = drmIoctl(vdev->fd, DRM_IOCTL_VIRTGPU_EXECBUFFER, &eb);
+    int fence_fd = (!ret && n_out) ? eb.fence_fd : -1;
+
+    pthread_mutex_unlock(&vdev->eb_lock);
+
+    if (ret)
+        return ret;
+
+    if (fence_fd >= 0) {
+        /* Wait for the GPU fence to signal before advancing timeline
+         * syncobjs. This ensures the GPU has actually completed the
+         * batch before we tell the media driver the surfaces are ready.
+         */
+        struct pollfd pfd = { .fd = fence_fd, .events = POLLIN };
+        while (poll(&pfd, 1, -1) == -1 && errno == EINTR)
+            ;
+        close(fence_fd);
+
+        /* Now signal each out-syncobj at its timeline point. */
+        for (uint32_t i = 0; i < args->num_syncs; i++) {
+            struct drm_xe_sync *s = &xe_syncs[i];
+            if (!(s->flags & DRM_XE_SYNC_FLAG_SIGNAL))
+                continue;
+
+            if (s->type == DRM_XE_SYNC_TYPE_TIMELINE_SYNCOBJ) {
+                struct drm_syncobj_timeline_array tsa;
+                memset(&tsa, 0, sizeof(tsa));
+                tsa.handles = (uintptr_t)&s->handle;
+                tsa.points  = (uintptr_t)&s->timeline_value;
+                tsa.count_handles = 1;
+                drmIoctl(g_vdrm_fd,
+                         DRM_IOCTL_SYNCOBJ_TIMELINE_SIGNAL, &tsa);
+            } else {
+                struct drm_syncobj_array sa;
+                memset(&sa, 0, sizeof(sa));
+                sa.handles = (uintptr_t)&s->handle;
+                sa.count_handles = 1;
+                drmIoctl(g_vdrm_fd, DRM_IOCTL_SYNCOBJ_SIGNAL, &sa);
+            }
+        }
+    }
+
+    return 0;
+}
+
+static int
+handle_exec_queue_get_property(struct vdrm_device *vdev,
+                               struct drm_xe_exec_queue_get_property *args)
+{
+    if (args->property == DRM_XE_EXEC_QUEUE_GET_PROPERTY_BAN) {
+        struct xe_shmem *shmem = (struct xe_shmem *)vdev->shmem;
+        if (shmem && args->exec_queue_id < 64) {
+            args->value = (shmem->banned_exec_queue_mask >>
+                           args->exec_queue_id) & 1;
+        } else {
+            args->value = 0;
+        }
+        return 0;
+    }
+    return -EINVAL;
+}
+
+static int
+handle_gem_close(struct vdrm_device *vdev, struct drm_gem_close *args)
+{
+    vdrm_bo_close(vdev, args->handle);
+    return 0;
+}
+
+/* ======================================================================
+ * Public API
+ * ====================================================================== */
+
+bool
+mos_xe_virtio_probe(int fd)
+{
+    struct virgl_renderer_capset_drm caps;
+
+    if (vdrm_get_capset(fd, &caps) != 0)
+        return false;
+
+    return caps.context_type == VIRTGPU_DRM_CONTEXT_XE;
+}
+
+int
+mos_xe_virtio_init(int fd)
+{
+    pthread_mutex_lock(&g_vdrm_global_lock);
+
+    if (g_vdrm && g_vdrm_fd == fd) {
+        /* Already initialized for this fd */
+        pthread_mutex_unlock(&g_vdrm_global_lock);
+        return 0;
+    }
+
+    if (g_vdrm) {
+        /* Different fd -- close old one first */
+        vdrm_disconnect(g_vdrm);
+        g_vdrm = NULL;
+        g_vdrm_fd = -1;
+    }
+
+    struct vdrm_device *vdev = vdrm_connect(fd);
+    if (!vdev) {
+        pthread_mutex_unlock(&g_vdrm_global_lock);
+        return -ENODEV;
+    }
+
+    g_vdrm = vdev;
+    g_vdrm_fd = fd;
+
+    pthread_mutex_unlock(&g_vdrm_global_lock);
+    return 0;
+}
+
+void
+mos_xe_virtio_fini(int fd)
+{
+    pthread_mutex_lock(&g_vdrm_global_lock);
+
+    if (g_vdrm && g_vdrm_fd == fd) {
+        vdrm_disconnect(g_vdrm);
+        g_vdrm = NULL;
+        g_vdrm_fd = -1;
+    }
+
+    pthread_mutex_unlock(&g_vdrm_global_lock);
+}
+
+bool
+mos_xe_virtio_is_active(int fd)
+{
+    return g_vdrm != NULL && g_vdrm_fd == fd;
+}
+
+int
+mos_xe_ioctl(int fd, unsigned long request, void *arg)
+{
+    struct vdrm_device *vdev = NULL;
+
+    /* Lazy init: if the fd matches a known virtio-gpu Xe fd but vdrm
+     * isn't connected yet, connect now.  This handles the case where
+     * device query functions are called before mos_xe_virtio_init().
+     */
+    if (!g_vdrm && g_vdrm_fd < 0 && mos_xe_virtio_probe(fd)) {
+        mos_xe_virtio_init(fd);
+    }
+
+    /* Fast path: if not on virtio, just call the real ioctl */
+    if (!g_vdrm || g_vdrm_fd != fd)
+        return drmIoctl(fd, request, arg);
+
+    vdev = g_vdrm;
+
+    switch (request) {
+    case DRM_IOCTL_XE_DEVICE_QUERY:
+        return handle_device_query(vdev, (struct drm_xe_device_query *)arg);
+
+    case DRM_IOCTL_XE_GEM_CREATE:
+        return handle_gem_create(vdev, (struct drm_xe_gem_create *)arg);
+
+    case DRM_IOCTL_XE_GEM_MMAP_OFFSET:
+        return handle_gem_mmap_offset(vdev, (struct drm_xe_gem_mmap_offset *)arg);
+
+    case DRM_IOCTL_XE_VM_CREATE:
+        return handle_vm_create(vdev, (struct drm_xe_vm_create *)arg);
+
+    case DRM_IOCTL_XE_VM_DESTROY:
+        return handle_vm_destroy(vdev, (struct drm_xe_vm_destroy *)arg);
+
+    case DRM_IOCTL_XE_VM_BIND:
+        return handle_vm_bind(vdev, (struct drm_xe_vm_bind *)arg);
+
+    case DRM_IOCTL_XE_EXEC_QUEUE_CREATE:
+        return handle_exec_queue_create(vdev, (struct drm_xe_exec_queue_create *)arg);
+
+    case DRM_IOCTL_XE_EXEC_QUEUE_DESTROY:
+        return handle_exec_queue_destroy(vdev, (struct drm_xe_exec_queue_destroy *)arg);
+
+    case DRM_IOCTL_XE_EXEC:
+        return handle_exec(vdev, (struct drm_xe_exec *)arg);
+
+    case DRM_IOCTL_XE_EXEC_QUEUE_GET_PROPERTY:
+        return handle_exec_queue_get_property(vdev,
+                (struct drm_xe_exec_queue_get_property *)arg);
+
+    case DRM_IOCTL_GEM_CLOSE:
+        return handle_gem_close(vdev, (struct drm_gem_close *)arg);
+
+    default:
+        /* SYNCOBJ_*, PRIME_*, etc. -- pass through to kernel.
+         * Use vdev->fd since handles/syncobjs live on our context fd
+         * (which may be a reopened fd if EEXIST was encountered).
+         */
+        return drmIoctl(vdev->fd, request, arg);
+    }
+}
+
+void *
+mos_xe_gem_mmap(int fd, uint32_t handle, size_t size)
+{
+    if (!g_vdrm || g_vdrm_fd != fd)
+        return MAP_FAILED;
+
+    struct drm_virtgpu_map req;
+    memset(&req, 0, sizeof(req));
+    req.handle = handle;
+
+    int vfd = g_vdrm->fd;
+    int ret = drmIoctl(vfd, DRM_IOCTL_VIRTGPU_MAP, &req);
+    if (ret) {
+        MOS_DRM_ASSERTMESSAGE("mos_xe_gem_mmap: VIRTGPU_MAP failed: %s",
+                              strerror(errno));
+        return MAP_FAILED;
+    }
+
+    void *map = mmap(NULL, size, PROT_READ | PROT_WRITE,
+                     MAP_SHARED, vfd, req.offset);
+    if (map == MAP_FAILED) {
+        MOS_DRM_ASSERTMESSAGE("mos_xe_gem_mmap: mmap failed: %s",
+                              strerror(errno));
+    }
+    return map;
+}
diff --git a/media_softlet/linux/common/os/xe/mos_xe_virtio.h b/media_softlet/linux/common/os/xe/mos_xe_virtio.h
new file mode 100644
index 0000000..70a32fd
--- /dev/null
+++ b/media_softlet/linux/common/os/xe/mos_xe_virtio.h
@@ -0,0 +1,67 @@
+/*
+ * Copyright 2025 Intel Corporation
+ * SPDX-License-Identifier: MIT
+ *
+ * Virtio-GPU native context support for Xe in the iHD media driver.
+ *
+ * When running inside a VM with virtio-gpu and the host exposes an
+ * Intel Xe GPU via native context, this layer transparently routes
+ * Xe DRM ioctls through the vdrm protocol so that mos_bufmgr_xe.c
+ * works without modification.
+ */
+
+#ifndef MOS_XE_VIRTIO_H
+#define MOS_XE_VIRTIO_H
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * Probe whether @p fd is a virtio-gpu device whose host exposes an
+ * Xe native context (VIRTGPU_DRM_CONTEXT_XE capset).
+ *
+ * Returns true if the fd is suitable for virtio Xe passthrough.
+ */
+bool mos_xe_virtio_probe(int fd);
+
+/**
+ * Initialize the vdrm proxy connection on @p fd.
+ * Call once during bufmgr init after mos_xe_virtio_probe() returned true.
+ *
+ * @return 0 on success, negative errno on failure.
+ */
+int mos_xe_virtio_init(int fd);
+
+/**
+ * Clean up the vdrm proxy for @p fd.
+ */
+void mos_xe_virtio_fini(int fd);
+
+/**
+ * Check whether the vdrm proxy is active on @p fd.
+ */
+bool mos_xe_virtio_is_active(int fd);
+
+/**
+ * ioctl wrapper -- routes Xe DRM ioctls through the vdrm protocol
+ * when running on virtio-gpu.  Falls through to drmIoctl() for
+ * non-Xe ioctls and when not on virtio-gpu.
+ */
+int mos_xe_ioctl(int fd, unsigned long request, void *arg);
+
+/**
+ * mmap wrapper for GEM objects -- uses VIRTGPU_MAP on virtio-gpu,
+ * returns MAP_FAILED on error.
+ */
+void *mos_xe_gem_mmap(int fd, uint32_t handle, size_t size);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* MOS_XE_VIRTIO_H */

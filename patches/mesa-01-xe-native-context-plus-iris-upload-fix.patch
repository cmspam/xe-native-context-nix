+   int32_t ret;
+   uint32_t pad2;
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_vm_bind_rsp)
+
+struct xe_ccmd_exec_queue_create_req {
+   struct vdrm_ccmd_req hdr;
+   uint32_t vm_id;
+   uint32_t flags;
+   uint16_t width;
+   uint16_t num_placements;
+   uint32_t pad;
+   uint8_t payload[];
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_exec_queue_create_req)
+
+struct xe_ccmd_exec_queue_create_rsp {
+   struct vdrm_ccmd_rsp hdr;
+   uint32_t pad;
+   int32_t ret;
+   uint32_t exec_queue_id;
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_exec_queue_create_rsp)
+
+struct xe_ccmd_exec_queue_destroy_req {
+   struct vdrm_ccmd_req hdr;
+   uint32_t exec_queue_id;
+   uint32_t pad;
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_exec_queue_destroy_req)

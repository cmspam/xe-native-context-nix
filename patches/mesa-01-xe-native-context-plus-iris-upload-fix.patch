+static bool
+xe_is_virtio_fd(int fd)
+{
+   drmVersionPtr version = drmGetVersion(fd);
+   bool is_virtio = version && version->name &&
+                    strcmp(version->name, "virtio_gpu") == 0;
+
+   if (version)
+      drmFreeVersion(version);
+
+   return is_virtio;
+}
+
+static uint64_t
+xe_clamp_virtio_sysmem_size(int fd, uint64_t host_size)
+{
+   uint64_t guest_total;
+
+   if (!xe_is_virtio_fd(fd))
+      return host_size;
+
+   if (!os_get_total_physical_memory(&guest_total))
+      return host_size;
+
+   return MIN2(host_size, guest_total);
+}

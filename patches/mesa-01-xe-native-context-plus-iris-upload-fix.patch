diff --git a/src/intel/dev/virtio/xe_virtio_ccmd.c b/src/intel/dev/virtio/xe_virtio_ccmd.c
new file mode 100644
index 0000000..0879945
--- /dev/null
+++ b/src/intel/dev/virtio/xe_virtio_ccmd.c
@@ -0,0 +1,304 @@
+/*
+ * Copyright 2025 Collabora, Ltd.
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "intel_virtio_priv.h"
+#include "xe_virtio_proto.h"
+
+int
+xe_virtio_device_query(struct intel_virtio_device *dev,
+                       struct drm_xe_device_query *args)
+{
+   struct xe_ccmd_device_query_req req = {
+      .hdr = XE_CCMD(DEVICE_QUERY, sizeof(req)),
+      .query = args->query,
+      .size = args->size,
+   };
+   struct xe_ccmd_device_query_rsp *rsp =
+      vdrm_alloc_rsp(dev->vdrm, &req.hdr, sizeof(*rsp) + args->size);
+   int err = vdrm_send_req(dev->vdrm, &req.hdr, true);
+
+   if (err)
+      return errno;
+
+   if (args->data && rsp->size > 0)
+      memcpy((void *)(uintptr_t)args->data, rsp->payload, rsp->size);
+
+   args->size = rsp->size;
+   return rsp->ret;
+}
+
+int
+xe_virtio_gem_create(struct intel_virtio_device *dev,
+                     struct drm_xe_gem_create *args)
+{
+   uint32_t blob_flags = VIRTGPU_BLOB_FLAG_USE_MAPPABLE |
+                         VIRTGPU_BLOB_FLAG_USE_SHAREABLE;
+   struct xe_ccmd_gem_create_req req = {
+      .hdr = XE_CCMD(GEM_CREATE, sizeof(req)),
+      .size = args->size,
+      .placement = args->placement,
+      .flags = args->flags,
+      .vm_id = args->vm_id,
+      .cpu_caching = args->cpu_caching,
+   };
+   int ret;
+
+   if (dev->vdrm->supports_cross_device)
+      blob_flags |= VIRTGPU_BLOB_FLAG_USE_CROSS_DEVICE;
+
+   req.blob_id = p_atomic_inc_return(&dev->next_blob_id);
+   ret = vdrm_bo_create(dev->vdrm, args->size, blob_flags, req.blob_id, &req.hdr);
+   if (!ret)
+      return EINVAL;
+
+   args->handle = ret;
+   return 0;
+}
+
+int
+xe_virtio_gem_close(struct intel_virtio_device *dev, struct drm_gem_close *args)
+{
+   vdrm_bo_close(dev->vdrm, args->handle);
+   return 0;
+}
+
+int
+xe_virtio_gem_mmap_offset(struct intel_virtio_device *dev,
+                          struct drm_xe_gem_mmap_offset *args)
+{
+   struct drm_virtgpu_map map_req = { .handle = args->handle };
+
+   if (drmIoctl(dev->fd, DRM_IOCTL_VIRTGPU_MAP, &map_req))
+      return errno;
+
+   args->offset = map_req.offset;
+   return 0;
+}
+
+int
+xe_virtio_vm_create(struct intel_virtio_device *dev,
+                    struct drm_xe_vm_create *args)
+{
+   struct xe_ccmd_vm_create_req req = {
+      .hdr = XE_CCMD(VM_CREATE, sizeof(req)),
+      .flags = args->flags,
+   };
+   struct xe_ccmd_vm_create_rsp *rsp =
+      vdrm_alloc_rsp(dev->vdrm, &req.hdr, sizeof(*rsp));
+   int err = vdrm_send_req(dev->vdrm, &req.hdr, true);
+
+   if (err)
+      return errno;
+
+   args->vm_id = rsp->vm_id;
+   return rsp->ret;
+}
+
+int
+xe_virtio_vm_destroy(struct intel_virtio_device *dev,
+                     struct drm_xe_vm_destroy *args)
+{
+   struct xe_ccmd_vm_destroy_req req = {
+      .hdr = XE_CCMD(VM_DESTROY, sizeof(req)),
+      .vm_id = args->vm_id,
+   };
+
+   return vdrm_send_req(dev->vdrm, &req.hdr, false);
+}
+
+int
+xe_virtio_vm_bind(struct intel_virtio_device *dev, struct drm_xe_vm_bind *args)
+{
+   uint32_t num_binds = args->num_binds;
+   struct drm_xe_vm_bind_op *bind_ops =
+      num_binds == 1 ? &args->bind :
+      (struct drm_xe_vm_bind_op *)(uintptr_t)args->vector_of_binds;
+   unsigned req_len = sizeof(struct xe_ccmd_vm_bind_req) +
+                      num_binds * sizeof(struct xe_ccmd_vm_bind_op);
+   uint8_t buf[req_len];
+   struct xe_ccmd_vm_bind_req *req = (void *)buf;
+   struct xe_ccmd_vm_bind_op *ccmd_ops = (void *)req->payload;
+   struct xe_ccmd_vm_bind_rsp *rsp;
+   int err;
+
+   req->hdr = XE_CCMD(VM_BIND, req_len);
+   req->vm_id = args->vm_id;
+   req->num_binds = num_binds;
+
+   for (uint32_t i = 0; i < num_binds; i++) {
+      ccmd_ops[i].res_id = bind_ops[i].obj ?
+         vdrm_handle_to_res_id(dev->vdrm, bind_ops[i].obj) : 0;
+      ccmd_ops[i].pat_index = bind_ops[i].pat_index;
+      ccmd_ops[i].pad = 0;
+      ccmd_ops[i].obj_offset = bind_ops[i].obj_offset;
+      ccmd_ops[i].range = bind_ops[i].range;
+      ccmd_ops[i].addr = bind_ops[i].addr;
+      ccmd_ops[i].op = bind_ops[i].op;
+      ccmd_ops[i].flags = bind_ops[i].flags;
+   }
+
+   rsp = vdrm_alloc_rsp(dev->vdrm, &req->hdr, sizeof(*rsp));
+   err = vdrm_send_req(dev->vdrm, &req->hdr, true);
+   if (err)
+      return errno;
+
+   if (rsp->ret)
+      return rsp->ret;
+
+   if (args->num_syncs) {
+      struct drm_xe_sync *syncs = (void *)(uintptr_t)args->syncs;
+
+      for (uint32_t i = 0; i < args->num_syncs; i++) {
+         if (!(syncs[i].flags & DRM_XE_SYNC_FLAG_SIGNAL))
+            continue;
+
+         if (syncs[i].type == DRM_XE_SYNC_TYPE_SYNCOBJ) {
+            dev->sync->signal(dev->sync, &syncs[i].handle, 1);
+         } else if (syncs[i].type == DRM_XE_SYNC_TYPE_TIMELINE_SYNCOBJ) {
+            uint64_t point = syncs[i].timeline_value;
+            dev->sync->timeline_signal(dev->sync, &syncs[i].handle, &point, 1);
+         }
+      }
+   }
+
+   return 0;
+}
+
+int
+xe_virtio_exec_queue_create(struct intel_virtio_device *dev,
+                            struct drm_xe_exec_queue_create *args)
+{
+   struct drm_xe_engine_class_instance *instances =
+      (void *)(uintptr_t)args->instances;
+   unsigned instances_size = sizeof(*instances) * args->width * args->num_placements;
+   unsigned req_len = sizeof(struct xe_ccmd_exec_queue_create_req) + instances_size;
+   uint8_t buf[req_len];
+   struct xe_ccmd_exec_queue_create_req *req = (void *)buf;
+   struct xe_ccmd_exec_queue_create_rsp *rsp;
+   int err;
+
+   req->hdr = XE_CCMD(EXEC_QUEUE_CREATE, req_len);
+   req->vm_id = args->vm_id;
+   req->flags = args->flags;
+   req->width = args->width;
+   req->num_placements = args->num_placements;
+   req->pad = 0;
+   memcpy(req->payload, instances, instances_size);
+
+   rsp = vdrm_alloc_rsp(dev->vdrm, &req->hdr, sizeof(*rsp));
+   err = vdrm_send_req(dev->vdrm, &req->hdr, true);
+   if (err)
+      return errno;
+
+   args->exec_queue_id = rsp->exec_queue_id;
+   return rsp->ret;
+}
+
+int
+xe_virtio_exec_queue_destroy(struct intel_virtio_device *dev,
+                             struct drm_xe_exec_queue_destroy *args)
+{
+   struct xe_ccmd_exec_queue_destroy_req req = {
+      .hdr = XE_CCMD(EXEC_QUEUE_DESTROY, sizeof(req)),
+      .exec_queue_id = args->exec_queue_id,
+   };
+
+   return vdrm_send_req(dev->vdrm, &req.hdr, false);
+}
+
+int
+xe_virtio_exec(struct intel_virtio_device *dev, struct drm_xe_exec *args)
+{
+   struct drm_xe_sync *xe_syncs = (void *)(uintptr_t)args->syncs;
+   uint32_t n_in = 0;
+   uint32_t n_out = 0;
+   struct drm_virtgpu_execbuffer_syncobj *in_so = NULL;
+   struct drm_virtgpu_execbuffer_syncobj *out_so = NULL;
+   struct xe_ccmd_exec_req ccmd_req = {
+      .hdr = XE_CCMD(EXEC, sizeof(ccmd_req)),
+      .exec_queue_id = args->exec_queue_id,
+      .num_batch_buffer = args->num_batch_buffer,
+      .address = args->address,
+   };
+   struct vdrm_execbuf_params p;
+   int ret;
+
+   for (uint32_t i = 0; i < args->num_syncs; i++) {
+      if (xe_syncs[i].flags & DRM_XE_SYNC_FLAG_SIGNAL)
+         n_out++;
+      else
+         n_in++;
+   }
+
+   if (n_in) {
+      in_so = calloc(n_in, sizeof(*in_so));
+      if (!in_so)
+         return ENOMEM;
+   }
+
+   if (n_out) {
+      out_so = calloc(n_out, sizeof(*out_so));
+      if (!out_so) {
+         free(in_so);
+         return ENOMEM;
+      }
+   }
+
+   for (uint32_t i = 0, w = 0, s = 0; i < args->num_syncs; i++) {
+      if (xe_syncs[i].flags & DRM_XE_SYNC_FLAG_SIGNAL) {
+         out_so[s].handle = xe_syncs[i].handle;
+         if (xe_syncs[i].type == DRM_XE_SYNC_TYPE_TIMELINE_SYNCOBJ)
+            out_so[s].point = xe_syncs[i].timeline_value;
+         else
+            out_so[s].point = 0;
+         s++;
+         continue;
+      }
+
+      in_so[w].handle = xe_syncs[i].handle;
+      if (xe_syncs[i].type == DRM_XE_SYNC_TYPE_TIMELINE_SYNCOBJ)
+         in_so[w].point = xe_syncs[i].timeline_value;
+      else
+         in_so[w].point = 0;
+      w++;
+   }
+
+   vdrm_alloc_rsp(dev->vdrm, &ccmd_req.hdr, sizeof(struct xe_ccmd_exec_rsp));
+
+   p = (struct vdrm_execbuf_params) {
+      .req = &ccmd_req.hdr,
+      .ring_idx = args->exec_queue_id + 1,
+      .in_syncobjs = in_so,
+      .out_syncobjs = out_so,
+      .num_in_syncobjs = n_in,
+      .num_out_syncobjs = n_out,
+   };
+
+   ret = vdrm_execbuf(dev->vdrm, &p);
+
+   free(in_so);
+   free(out_so);
+   return ret;
+}
+
+int
+xe_virtio_exec_queue_get_property(struct intel_virtio_device *dev,
+                                  struct drm_xe_exec_queue_get_property *args)
+{
+   if (args->property == DRM_XE_EXEC_QUEUE_GET_PROPERTY_BAN) {
+      struct xe_shmem *shmem = to_xe_shmem(dev->vdrm->shmem);
+
+      if (args->exec_queue_id < 64 &&
+          (p_atomic_read(&shmem->banned_exec_queue_mask) &
+           (1ULL << args->exec_queue_id)))
+         args->value = 1;
+      else
+         args->value = 0;
+
+      return 0;
+   }
+
+   return EINVAL;
+}
